#!/bin/busybox sh
export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
export HOME=/root

mount -t devtmpfs devtmpfs /dev 2>/dev/null || mount -t tmpfs tmpfs /dev
mkdir -p /dev/pts /dev/shm /proc /sys /run /tmp
mount -t devpts devpts /dev/pts 2>/dev/null || true
mount -t proc proc /proc 2>/dev/null || true
mount -t sysfs sysfs /sys 2>/dev/null || true
mount -t tmpfs -o mode=0755 tmpfs /run 2>/dev/null || true
mount -t tmpfs -o mode=1777 tmpfs /tmp 2>/dev/null || true

[ -c /dev/console ] || mknod -m 600 /dev/console c 5 1
[ -c /dev/null ] || mknod -m 666 /dev/null c 1 3

if [ -x /sbin/mdev ]; then
    echo /sbin/mdev > /proc/sys/kernel/hotplug 2>/dev/null || true
    /sbin/mdev -s 2>/dev/null || true
fi

hostname alpine-initramfs 2>/dev/null || true
cat > /etc/motd <<'EOF'
Alpine initramfs is up.
Type `uname -a`, `cat /proc/cmdline`, or `poweroff`.
EOF

cat <<'EOF'

========================================
 Alpine custom initramfs booted
========================================
EOF
uname -a || true
echo "cmdline: $(cat /proc/cmdline 2>/dev/null)"
echo ""
echo "Starting interactive shell on the kernel console..."
echo ""

exec /bin/sh </dev/console >/dev/console 2>&1
